# ============================================================
# ACCRUE — Environment Variables
# ============================================================
# 1. Copy this file and rename the copy to .env
# 2. Fill in every value below with your actual keys
# 3. Never commit .env to GitHub — it is in .gitignore
# ============================================================


# ============================================================
# SUPABASE — https://supabase.com/dashboard/project/_/settings/api
# ============================================================
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=


# ============================================================
# PLAID — https://dashboard.plaid.com/team/keys
# Keep VITE_PLAID_ENV=sandbox until you are ready to go live
# ============================================================
VITE_PLAID_CLIENT_ID=
VITE_PLAID_SECRET=
VITE_PLAID_ENV=sandbox


# ============================================================
# GEMINI (Google AI Studio) — https://aistudio.google.com/app/apikey
# Used server-side only — never exposed to the browser
# ============================================================
GEMINI_API_KEY=


# ============================================================
# SERVER
# Set to "production" when deploying live
# ============================================================
NODE_ENV=development
PORT=3000